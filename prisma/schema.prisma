// Prisma schema for mitchelturner.dev
//
// Models:
//   Project — manually curated showcase items (managed via /admin)
//   Vote    — anonymous upvotes for showcase projects
//   Setting — key/value config (e.g. GitHub username from admin dashboard)
//
// SQLite keeps local development self-contained. For production serverless,
// prefer GITHUB_USERNAME env or github.config.json over DB-backed settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  summary     String
  description String
  // "hardware" | "software"
  category    String
  // "idea" | "mockup" | "prototype" | "in_progress" | "completed"
  stage       String   @default("idea")
  imageUrl    String?
  demoUrl     String?
  // Comma-separated list of tags (SQLite has no native array type).
  tags        String   @default("")
  featured    Boolean  @default(false)
  voteCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes Vote[]
}

// Simple key/value store for editable app configuration (e.g. GitHub username).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Vote {
  id        String   @id @default(cuid())
  projectId String
  // Anonymous voter identity persisted in the browser (localStorage).
  voterKey  String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, voterKey])
  @@index([projectId])
}
