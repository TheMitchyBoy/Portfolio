{
  "name": "mitchelturner-dev",
  "version": "0.1.0",
  "description": "Personal portfolio site — auto-synced GitHub work, about page, and hidden admin dashboard.",
  "author": "Mitchel Turner <https://github.com/TheMitchyBoy>",
  "license": "MIT",
  "homepage": "https://mitchelturner.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheMitchyBoy/Portfolio.git"
  },
  "keywords": [
    "portfolio",
    "nextjs",
    "github",
    "typescript",
    "tailwindcss",
    "prisma"
  ],
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.40.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
